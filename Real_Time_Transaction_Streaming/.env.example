# Environment variables for Project 01: Real-Time M-Pesa Transaction Streaming
#
# Copy to `.env` and fill in real values. Do not commit `.env`.

# Runtime
LOG_LEVEL=INFO

# PostgreSQL (local docker-compose defaults)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mpesa_analytics
POSTGRES_USER=data_engineer
POSTGRES_PASSWORD=change_me

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_TRANSACTIONS=mpesa-transactions
KAFKA_TOPIC_ALERTS=mpesa-fraud-alerts
KAFKA_GROUP_ID=mpesa_streaming_group

# Safaricom Daraja (set these from your Daraja app)
DARAJA_ENVIRONMENT=sandbox
DARAJA_CONSUMER_KEY=your_consumer_key
DARAJA_CONSUMER_SECRET=your_consumer_secret
MPESA_BUSINESS_SHORTCODE=your_shortcode
MPESA_PASSKEY=your_lipa_na_mpesa_passkey

# Webhooks / callbacks
CALLBACK_URL=https://example.com/callback

